{
  "Comment": "Data Pipeline Orchestration",
  "StartAt": "FetchAdscribeData",
  "States": {
    "FetchAdscribeData": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:ap-southeast-1:743298171118:function:de-ascend-adscribe-consumer",
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 10,
          "MaxAttempts": 2,
          "BackoffRate": 2
        }
      ],
      "End": true
    }
  }
}